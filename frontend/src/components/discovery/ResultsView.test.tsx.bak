/**
 * ResultsView.test.tsx
 *
 * Run with:  npx vitest
 * Requires:  npm install -D vitest @testing-library/react @testing-library/user-event jsdom
 *
 * Add to vite.config.ts (or vitest.config.ts):
 *   test: { environment: 'jsdom', globals: true, setupFiles: './src/test/setup.ts' }
 *
 * setup.ts:
 *   import '@testing-library/jest-dom';
 */

import { describe, it, expect, vi, beforeEach } from 'vitest';
import { render, screen, within } from '@testing-library/react';
import userEvent from '@testing-library/user-event';
import { ResultsView } from './ResultsView';
import { PasswordManager, type Credential } from './PasswordManager';

// ---------------------------------------------------------------------------
// Shared helpers
// ---------------------------------------------------------------------------

type Confidence = 'High' | 'Medium' | 'Low';

function makeAsset(overrides: Partial<{ id: number; name: string; confidence: Confidence }> = {}) {
  return {
    id:         overrides.id         ?? 1,
    name:       overrides.name       ?? 'Test Asset',
    confidence: overrides.confidence ?? 'High',
    type:       'subscription',
    username:   'user@test.com',
    password:   'secret',
  };
}

function makeAssets(count: number, confidence: Confidence = 'High') {
  return Array.from({ length: count }, (_, i) =>
    makeAsset({ id: i + 1, name: `Asset ${i + 1}`, confidence })
  );
}

// Re-implementation of the exact filter from ResultsView so we can unit-test
// the logic in isolation (no DOM needed).
function applyDisplayFilter(assets: ReturnType<typeof makeAsset>[]) {
  let lowConfidenceShown = 0;
  return assets.filter((asset) => {
    if (asset.confidence !== 'Low') return true;
    if (lowConfidenceShown < 5) { lowConfidenceShown += 1; return true; }
    return false;
  });
}

// ---------------------------------------------------------------------------
// 1. displayedAssets filter logic (pure, no DOM)
// ---------------------------------------------------------------------------

describe('displayedAssets filter — low-confidence cap', () => {
  it('shows all assets when none are Low confidence', () => {
    const assets = makeAssets(10, 'High');
    expect(applyDisplayFilter(assets)).toHaveLength(10);
  });

  it('shows all assets when none are Low confidence (Medium)', () => {
    const assets = makeAssets(7, 'Medium');
    expect(applyDisplayFilter(assets)).toHaveLength(7);
  });

  it('caps Low-confidence assets at exactly 5', () => {
    const assets = makeAssets(8, 'Low');
    expect(applyDisplayFilter(assets)).toHaveLength(5);
  });

  it('shows exactly 5 Low when there are more than 5', () => {
    const assets = makeAssets(20, 'Low');
    const displayed = applyDisplayFilter(assets);
    const lowCount = displayed.filter((a) => a.confidence === 'Low').length;
    expect(lowCount).toBe(5);
  });

  it('shows all Low when there are fewer than 5', () => {
    const assets = makeAssets(3, 'Low');
    expect(applyDisplayFilter(assets)).toHaveLength(3);
  });

  it('shows exactly 5 Low when there are exactly 5', () => {
    const assets = makeAssets(5, 'Low');
    expect(applyDisplayFilter(assets)).toHaveLength(5);
  });

  it('always shows High and Medium regardless of position', () => {
    const assets = [
      makeAsset({ id: 1, confidence: 'High' }),
      makeAsset({ id: 2, confidence: 'Medium' }),
      makeAsset({ id: 3, confidence: 'Low' }),
    ];
    const displayed = applyDisplayFilter(assets);
    expect(displayed).toHaveLength(3);
  });

  it('mixes High + Low correctly — keeps all High, caps Low at 5', () => {
    const highs = makeAssets(4, 'High');
    const lows  = makeAssets(8, 'Low').map((a, i) => ({ ...a, id: 100 + i }));
    const displayed = applyDisplayFilter([...highs, ...lows]);
    const highCount = displayed.filter((a) => a.confidence === 'High').length;
    const lowCount  = displayed.filter((a) => a.confidence === 'Low').length;
    expect(highCount).toBe(4);
    expect(lowCount).toBe(5);
    expect(displayed).toHaveLength(9);
  });

  it('returns an empty array when given no assets', () => {
    expect(applyDisplayFilter([])).toHaveLength(0);
  });
});

// ---------------------------------------------------------------------------
// 2. selectedAssets — index alignment with displayedAssets
// ---------------------------------------------------------------------------

describe('selectedAssets index alignment', () => {
  const onAddAssets = vi.fn();
  const onCancel    = vi.fn();

  beforeEach(() => { vi.clearAllMocks(); });

  it('initialises selection based on displayedAssets length, not raw assets', () => {
    // 8 Low-confidence assets → only 5 are displayed → 5 indices selected
    const assets = makeAssets(8, 'Low');
    render(<ResultsView assets={assets} onAddAssets={onAddAssets} onCancel={onCancel} />);
    // Footer should read "5 of 5 selected", never "8 of 8 selected"
    expect(screen.getByText(/5 of 5 selected/i)).toBeInTheDocument();
    expect(screen.queryByText(/8 of 8 selected/i)).not.toBeInTheDocument();
  });

  it('no selected index exceeds displayedAssets.length - 1', () => {
    const assets = makeAssets(8, 'Low'); // only 5 displayed
    render(<ResultsView assets={assets} onAddAssets={onAddAssets} onCancel={onCancel} />);
    // "5 of 5" means the max index in selectedAssets is 4, which is < 5 ✓
    expect(screen.getByText(/5 of 5 selected/i)).toBeInTheDocument();
  });

  it('when all assets are High, all are selected initially', () => {
    const assets = makeAssets(6, 'High');
    render(<ResultsView assets={assets} onAddAssets={onAddAssets} onCancel={onCancel} />);
    expect(screen.getByText(/6 of 6 selected/i)).toBeInTheDocument();
  });
});

// ---------------------------------------------------------------------------
// 3. selectAll / deselectAll
// ---------------------------------------------------------------------------

describe('selectAll and deselectAll', () => {
  const onAddAssets = vi.fn();
  const onCancel    = vi.fn();

  beforeEach(() => { vi.clearAllMocks(); });

  it('selectAll selects all displayedAssets (not raw assets)', async () => {
    const user   = userEvent.setup();
    const assets = makeAssets(8, 'Low'); // 5 displayed
    render(<ResultsView assets={assets} onAddAssets={onAddAssets} onCancel={onCancel} />);

    await user.click(screen.getByRole('button', { name: /deselect all/i }));
    expect(screen.getByText(/0 of 5 selected/i)).toBeInTheDocument();

    await user.click(screen.getByRole('button', { name: /select all/i }));
    expect(screen.getByText(/5 of 5 selected/i)).toBeInTheDocument();
  });

  it('deselectAll clears all selections', async () => {
    const user   = userEvent.setup();
    const assets = makeAssets(6, 'High');
    render(<ResultsView assets={assets} onAddAssets={onAddAssets} onCancel={onCancel} />);

    await user.click(screen.getByRole('button', { name: /deselect all/i }));
    expect(screen.getByText(/0 of 6 selected/i)).toBeInTheDocument();
  });

  it('selectAll after deselectAll restores full displayed count', async () => {
    const user   = userEvent.setup();
    const assets = makeAssets(6, 'High');
    render(<ResultsView assets={assets} onAddAssets={onAddAssets} onCancel={onCancel} />);

    await user.click(screen.getByRole('button', { name: /deselect all/i }));
    await user.click(screen.getByRole('button', { name: /select all/i }));
    expect(screen.getByText(/6 of 6 selected/i)).toBeInTheDocument();
  });
});

// ---------------------------------------------------------------------------
// 4. Footer count strings
// ---------------------------------------------------------------------------

describe('footer count strings use displayedAssets length', () => {
  const onAddAssets = vi.fn();
  const onCancel    = vi.fn();

  it('shows "Found N potential assets" using displayedAssets.length', () => {
    const assets = makeAssets(8, 'Low'); // only 5 displayed
    render(<ResultsView assets={assets} onAddAssets={onAddAssets} onCancel={onCancel} />);
    expect(screen.getByText(/found 5 potential asset/i)).toBeInTheDocument();
    expect(screen.queryByText(/found 8 potential asset/i)).not.toBeInTheDocument();
  });

  it('uses singular "asset" when displayedAssets.length is 1', () => {
    const assets = [makeAsset({ confidence: 'High' })];
    render(<ResultsView assets={assets} onAddAssets={onAddAssets} onCancel={onCancel} />);
    expect(screen.getByText(/found 1 potential asset[^s]/i)).toBeInTheDocument();
  });

  it('uses plural "assets" when displayedAssets.length > 1', () => {
    const assets = makeAssets(3, 'High');
    render(<ResultsView assets={assets} onAddAssets={onAddAssets} onCancel={onCancel} />);
    expect(screen.getByText(/found 3 potential assets/i)).toBeInTheDocument();
  });
});

// ---------------------------------------------------------------------------
// 5. Individual asset toggle (checkbox behaviour)
// ---------------------------------------------------------------------------

describe('individual asset toggle', () => {
  const onAddAssets = vi.fn();
  const onCancel    = vi.fn();

  beforeEach(() => { vi.clearAllMocks(); });

  it('unchecking one asset decrements the selected count', async () => {
    const user   = userEvent.setup();
    const assets = makeAssets(3, 'High');
    render(<ResultsView assets={assets} onAddAssets={onAddAssets} onCancel={onCancel} />);

    expect(screen.getByText(/3 of 3 selected/i)).toBeInTheDocument();
    // Click the first asset checkbox/row
    const checkboxes = screen.getAllByRole('checkbox');
    await user.click(checkboxes[0]);
    expect(screen.getByText(/2 of 3 selected/i)).toBeInTheDocument();
  });

  it('re-checking an asset increments the count again', async () => {
    const user   = userEvent.setup();
    const assets = makeAssets(3, 'High');
    render(<ResultsView assets={assets} onAddAssets={onAddAssets} onCancel={onCancel} />);

    const checkboxes = screen.getAllByRole('checkbox');
    await user.click(checkboxes[0]); // uncheck
    await user.click(checkboxes[0]); // re-check
    expect(screen.getByText(/3 of 3 selected/i)).toBeInTheDocument();
  });
});

// ---------------------------------------------------------------------------
// 6. onAddAssets callback
// ---------------------------------------------------------------------------

describe('onAddAssets callback', () => {
  const onCancel = vi.fn();

  beforeEach(() => { vi.clearAllMocks(); });

  it('calls onAddAssets with only the selected assets', async () => {
    const user        = userEvent.setup();
    const onAddAssets = vi.fn();
    const assets      = makeAssets(3, 'High');
    render(<ResultsView assets={assets} onAddAssets={onAddAssets} onCancel={onCancel} />);

    // Deselect the first asset
    const checkboxes = screen.getAllByRole('checkbox');
    await user.click(checkboxes[0]);

    await user.click(screen.getByRole('button', { name: /add/i }));
    expect(onAddAssets).toHaveBeenCalledOnce();
    const passed = onAddAssets.mock.calls[0][0];
    expect(passed).toHaveLength(2);
  });

  it('does not call onAddAssets when nothing is selected', async () => {
    const user        = userEvent.setup();
    const onAddAssets = vi.fn();
    const assets      = makeAssets(3, 'High');
    render(<ResultsView assets={assets} onAddAssets={onAddAssets} onCancel={onCancel} />);

    await user.click(screen.getByRole('button', { name: /deselect all/i }));
    const addButton = screen.getByRole('button', { name: /add/i });
    expect(addButton).toBeDisabled();
    expect(onAddAssets).not.toHaveBeenCalled();
  });
});

// ---------------------------------------------------------------------------
// 7. PasswordManager — reveal / copy / delete
// ---------------------------------------------------------------------------

const DEMO_CREDS: Credential[] = [
  { id: 1, name: 'Netflix',   username: 'jane@email.com', password: 'Netfl1x$ecure!', category: 'streaming',    confidence: 'High'   },
  { id: 2, name: 'Chase Bank',username: 'jane.doe',       password: 'Ch@se#9821',     category: 'finance',      confidence: 'High'   },
  { id: 3, name: 'Dropbox',   username: 'jane@email.com', password: 'drop',           category: 'subscription', confidence: 'Low'    },
];

describe('PasswordManager — credential reveal', () => {
  it('masks password by default', async () => {
    const user = userEvent.setup();
    render(<PasswordManager initialCredentials={DEMO_CREDS} />);

    await user.click(screen.getByText('Netflix'));
    expect(screen.queryByText('Netfl1x$ecure!')).not.toBeInTheDocument();
    expect(screen.getByText('••••••••••')).toBeInTheDocument();
  });

  it('reveals password when show button is clicked', async () => {
    const user = userEvent.setup();
    render(<PasswordManager initialCredentials={DEMO_CREDS} />);

    await user.click(screen.getByText('Netflix'));
    await user.click(screen.getByTitle('Show'));
    expect(screen.getByText('Netfl1x$ecure!')).toBeInTheDocument();
  });

  it('hides password again when hide button is clicked', async () => {
    const user = userEvent.setup();
    render(<PasswordManager initialCredentials={DEMO_CREDS} />);

    await user.click(screen.getByText('Netflix'));
    await user.click(screen.getByTitle('Show'));
    await user.click(screen.getByTitle('Hide'));
    expect(screen.queryByText('Netfl1x$ecure!')).not.toBeInTheDocument();
  });
});

describe('PasswordManager — delete credential', () => {
  it('removes credential from the list', async () => {
    const user = userEvent.setup();
    render(<PasswordManager initialCredentials={DEMO_CREDS} />);

    await user.click(screen.getByText('Netflix'));
    await user.click(screen.getByText('Remove'));
    expect(screen.queryByText('Netflix')).not.toBeInTheDocument();
  });

  it('keeps other credentials after deleting one', async () => {
    const user = userEvent.setup();
    render(<PasswordManager initialCredentials={DEMO_CREDS} />);

    await user.click(screen.getByText('Netflix'));
    await user.click(screen.getByText('Remove'));
    expect(screen.getByText('Chase Bank')).toBeInTheDocument();
    expect(screen.getByText('Dropbox')).toBeInTheDocument();
  });

  it('calls onSave with updated list after delete', async () => {
    const user   = userEvent.setup();
    const onSave = vi.fn();
    render(<PasswordManager initialCredentials={DEMO_CREDS} onSave={onSave} />);

    await user.click(screen.getByText('Netflix'));
    await user.click(screen.getByText('Remove'));
    expect(onSave).toHaveBeenCalledOnce();
    const saved: Credential[] = onSave.mock.calls[0][0];
    expect(saved.find((c) => c.name === 'Netflix')).toBeUndefined();
    expect(saved).toHaveLength(2);
  });
});

describe('PasswordManager — add credential', () => {
  it('adds a new credential and shows it in the list', async () => {
    const user = userEvent.setup();
    render(<PasswordManager initialCredentials={[]} />);

    await user.click(screen.getByText(/add credential/i));
    await user.type(screen.getByPlaceholderText(/e.g. Netflix/i), 'Hulu');
    await user.type(screen.getByPlaceholderText(/user@email.com/i), 'test@email.com');
    await user.type(screen.getByPlaceholderText('Password'), 'Hulu!Pass1');
    await user.click(screen.getByRole('button', { name: /save/i }));

    expect(screen.getByText('Hulu')).toBeInTheDocument();
  });

  it('does not add when required fields are empty', async () => {
    const user = userEvent.setup();
    render(<PasswordManager initialCredentials={[]} />);

    await user.click(screen.getByText(/add credential/i));
    await user.click(screen.getByRole('button', { name: /save/i }));

    // Modal should still be open (no credential was added)
    expect(screen.getByPlaceholderText(/e.g. Netflix/i)).toBeInTheDocument();
  });

  it('calls onSave with the new credential included', async () => {
    const user   = userEvent.setup();
    const onSave = vi.fn();
    render(<PasswordManager initialCredentials={DEMO_CREDS} onSave={onSave} />);

    await user.click(screen.getByText(/add credential/i));
    await user.type(screen.getByPlaceholderText(/e.g. Netflix/i), 'Disney+');
    await user.type(screen.getByPlaceholderText(/user@email.com/i), 'jane@email.com');
    await user.type(screen.getByPlaceholderText('Password'), 'Disney1!');
    await user.click(screen.getByRole('button', { name: /save/i }));

    expect(onSave).toHaveBeenCalledOnce();
    const saved: Credential[] = onSave.mock.calls[0][0];
    expect(saved.find((c) => c.name === 'Disney+')).toBeDefined();
    expect(saved).toHaveLength(4);
  });
});

describe('PasswordManager — search and filter', () => {
  it('filters credentials by name search', async () => {
    const user = userEvent.setup();
    render(<PasswordManager initialCredentials={DEMO_CREDS} />);

    await user.type(screen.getByPlaceholderText(/search/i), 'Netflix');
    expect(screen.getByText('Netflix')).toBeInTheDocument();
    expect(screen.queryByText('Chase Bank')).not.toBeInTheDocument();
  });

  it('filters credentials by username search', async () => {
    const user = userEvent.setup();
    render(<PasswordManager initialCredentials={DEMO_CREDS} />);

    await user.type(screen.getByPlaceholderText(/search/i), 'jane.doe');
    expect(screen.getByText('Chase Bank')).toBeInTheDocument();
    expect(screen.queryByText('Netflix')).not.toBeInTheDocument();
  });

  it('shows "no credentials found" when search has no matches', async () => {
    const user = userEvent.setup();
    render(<PasswordManager initialCredentials={DEMO_CREDS} />);

    await user.type(screen.getByPlaceholderText(/search/i), 'zzznomatch');
    expect(screen.getByText(/no credentials found/i)).toBeInTheDocument();
  });

  it('filters by category tab — streaming only', async () => {
    const user = userEvent.setup();
    render(<PasswordManager initialCredentials={DEMO_CREDS} />);

    await user.click(screen.getByRole('button', { name: /streaming/i }));
    expect(screen.getByText('Netflix')).toBeInTheDocument();
    expect(screen.queryByText('Chase Bank')).not.toBeInTheDocument();
    expect(screen.queryByText('Dropbox')).not.toBeInTheDocument();
  });

  it('all tab shows every credential', async () => {
    const user = userEvent.setup();
    render(<PasswordManager initialCredentials={DEMO_CREDS} />);

    await user.click(screen.getByRole('button', { name: /streaming/i }));
    await user.click(screen.getByRole('button', { name: /^all$/i }));
    expect(screen.getByText('Netflix')).toBeInTheDocument();
    expect(screen.getByText('Chase Bank')).toBeInTheDocument();
    expect(screen.getByText('Dropbox')).toBeInTheDocument();
  });
});